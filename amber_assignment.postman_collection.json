{
	"info": {
		"_postman_id": "a9a3b8cd-962a-43d9-9524-118df283d789",
		"name": "Amber Quote Management & Document Analysis API",
		"description": "Postman collection for the Backend Internship Assignment integrating Express, TypeScript, Prisma, and a mock FastAPI service.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Health Check",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{base_url}}/health",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"health"
					]
				},
				"description": "Checks the health status of the application."
			},
			"response": []
		},
		{
			"name": "Create Quote Request",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"const response = pm.response.json();",
							"if (response && response.data && response.data.id) {",
							"    pm.collectionVariables.set(\"quote_id\", response.data.id);",
							"}"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"customer\": \"Acme Builders\",\n  \"project\": \"Warehouse extension\",\n  \"estimatedValue\": 125000\n}"
				},
				"url": {
					"raw": "{{base_url}}/quotes",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"quotes"
					]
				},
				"description": "Creates a new Quote Request with client details and project description."
			},
			"response": []
		},
		{
			"name": "List Quotes (Paginated)",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{base_url}}/quotes?page=1&limit=10",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"quotes"
					],
					"query": [
						{
							"key": "page",
							"value": "1"
						},
						{
							"key": "limit",
							"value": "10"
						}
					]
				},
				"description": "Returns a paginated list of all Quote Requests, including their latest document analysis result."
			},
			"response": []
		},
		{
			"name": "Get Quote Details",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{base_url}}/quotes/{{quote_id}}",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"quotes",
						"{{quote_id}}"
					]
				},
				"description": "Retrieves the details of a single Quote Request by its unique ID, including the complete analysis history."
			},
			"response": []
		},
		{
			"name": "Analyze Quote (Trigger FastAPI)",
			"request": {
				"method": "POST",
				"header": [],
				"url": {
					"raw": "{{base_url}}/quotes/{{quote_id}}/analyze",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"quotes",
						"{{quote_id}}",
						"analyze"
					]
				},
				"description": "Triggers document analysis for the quote, calls the FastAPI service, stores the result, and returns the analysis report."
			},
			"response": []
		},
		{
			"name": "Update Quote Status",
			"request": {
				"method": "PATCH",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"status\": \"IN_REVIEW\"\n}"
				},
				"url": {
					"raw": "{{base_url}}/quotes/{{quote_id}}/status",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"quotes",
						"{{quote_id}}",
						"status"
					]
				},
				"description": "Updates the workflow status of the Quote Request. Allowed values: NEW, IN_REVIEW, NEEDS_INFO, COMPLETED."
			},
			"response": []
		},
		{
			"name": "Validation Error (Negative Value)",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"customer\": \"Acme Builders\",\n  \"project\": \"Warehouse extension\",\n  \"estimatedValue\": -500\n}"
				},
				"url": {
					"raw": "{{base_url}}/quotes",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"quotes"
					]
				},
				"description": "Test case demonstrating the validation failure when estimatedValue is negative."
			},
			"response": []
		},
		{
			"name": "Validation Error (Invalid Status)",
			"request": {
				"method": "PATCH",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"status\": \"ARCHIVED\"\n}"
				},
				"url": {
					"raw": "{{base_url}}/quotes/{{quote_id}}/status",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"quotes",
						"{{quote_id}}",
						"status"
					]
				},
				"description": "Test case demonstrating the validation failure when the status value is not one of the allowed statuses."
			},
			"response": []
		}
	],
	"variable": [
		{
			"key": "base_url",
			"value": "http://localhost:3000",
			"type": "string"
