generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model QuoteRequest {
  id             String           @id @default(cuid())
  customer       String
  project        String
  status         String           @default("New")
  estimatedValue Float
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  analyses       AnalysisResult[]

  @@map("quote_requests")
}

model AnalysisResult {
  id            String       @id @default(cuid())
  quote_id      String
  risk          String
  confidence    Float
  missing_items Json
  rawResponse   Json?
  analyzed_at   DateTime     @default(now())
  quote         QuoteRequest @relation(fields: [quote_id], references: [id], onDelete: Cascade)

  @@index([quote_id, analyzed_at])
  @@map("analysis_results")
}

